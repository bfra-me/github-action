{
  "name": "github-action",
  "version": "0.0.0-development",
  "private": true,
  "description": "GitHub Action template repository for bfra.me.",
  "keywords": [
    "github-actions",
    "nodejs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bfra-me/github-action.git"
  },
  "license": "MIT",
  "author": "Marcus R. Brown <git@mrbro.dev>",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bootstrap": "pnpm install --prefer-offline --loglevel warn",
    "build": "tsup",
    "build-release": "tsup --minify",
    "check-types": "tsc --noEmit",
    "fix": "eslint --fix",
    "postinstall": "simple-git-hooks",
    "lint": "eslint",
    "test": "vitest run"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,jsx,tsx,css,md,json,yaml,yml}": [
      "pnpm run fix"
    ]
  },
  "prettier": "@bfra.me/prettier-config/120-proof",
  "dependencies": {
    "@actions/core": "3.0.1"
  },
  "devDependencies": {
    "@bfra.me/eslint-config": "0.51.1",
    "@bfra.me/prettier-config": "0.16.9",
    "@bfra.me/tsconfig": "0.13.1",
    "@semantic-release/git": "10.0.1",
    "@types/node": "24.13.3",
    "@vitest/eslint-plugin": "1.6.23",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "esbuild-plugin-license": "1.2.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-prettier": "5.5.6",
    "jiti": "2.7.0",
    "js-yaml": "4.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.9.5",
    "semantic-release": "25.0.7",
    "simple-git-hooks": "2.13.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.14.0"
}
